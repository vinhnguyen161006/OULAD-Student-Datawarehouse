# ============================================================
# OULAD Student Data Warehouse — Environment template
# ============================================================
# Copy file này sang `.env` và chỉnh nếu cần.
#   cp .env.example .env
#
# .env đã được .gitignore — không commit credential thật.
# ============================================================

# --- MySQL (DWH + Mart) ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=student_dwh

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.

# --- MinIO (S3-compatible object storage) ---
# Mặc định trùng credential của Docker Compose để dev local nhanh.
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin

# --- dbt (Mart adapter) ---
# Đọc từ profiles.yml — chỉ override khi cần.
# DBT_HOST=mysql
# DBT_USER=root
# DBT_PASSWORD=rootpassword
